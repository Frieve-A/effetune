{
  "type": "DattorroPlateReverbPlugin",
  "tolerance": { "abs": 0.0001, "policy": "per-sample" },
  "fields": [
    { "name": "preDelay", "key": "pd", "kind": "float", "min": 0, "max": 100, "default": 10, "unit": "ms" },
    { "name": "bandwidth", "key": "bw", "kind": "float", "min": 0, "max": 1, "default": 0.9995 },
    { "name": "inputDiffusion1", "key": "id1", "kind": "float", "min": 0, "max": 1, "default": 0.75 },
    { "name": "inputDiffusion2", "key": "id2", "kind": "float", "min": 0, "max": 1, "default": 0.625 },
    { "name": "decay", "key": "dc", "kind": "float", "min": 0, "max": 1, "default": 0.5 },
    { "name": "decayDiffusion1", "key": "dd1", "kind": "float", "min": 0, "max": 1, "default": 0.7 },
    { "name": "damping", "key": "dp", "kind": "float", "min": 0, "max": 1, "default": 0.0005 },
    { "name": "modulationDepth", "key": "md", "kind": "float", "min": 0, "max": 16, "default": 1, "unit": "samples" },
    { "name": "modulationRate", "key": "mr", "kind": "float", "min": 0, "max": 10, "default": 1, "unit": "Hz" },
    { "name": "wetMix", "key": "wm", "kind": "int", "min": 0, "max": 100, "default": 30, "unit": "%" },
    { "name": "dryMix", "key": "dm", "kind": "int", "min": 0, "max": 100, "default": 100, "unit": "%" }
  ]
}
