{
  "type": "NoiseBlenderPlugin",
  "tolerance": { "abs": 0.00001, "policy": "per-sample" },
  "fields": [
    { "name": "noiseType", "key": "nt", "kind": "enum", "values": ["white", "pink", "brown"], "default": "pink" },
    { "name": "level", "key": "lv", "kind": "float", "min": -96, "max": 0, "default": -36, "unit": "dB" },
    { "name": "perChannel", "key": "pc", "kind": "bool", "default": true }
  ]
}
