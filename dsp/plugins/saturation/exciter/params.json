{
  "type": "ExciterPlugin",
  "tolerance": { "abs": 0.00001, "policy": "per-sample" },
  "fields": [
    { "name": "highPassFrequency", "key": "hf", "kind": "float", "min": 500, "max": 10000, "default": 3000, "unit": "Hz" },
    { "name": "highPassSlope", "key": "hs", "kind": "int", "min": 0, "max": 2, "default": 1 },
    { "name": "drive", "key": "dr", "kind": "float", "min": 0, "max": 10, "default": 3 },
    { "name": "bias", "key": "bs", "kind": "float", "min": -0.3, "max": 0.3, "default": 0.1 },
    { "name": "mix", "key": "mx", "kind": "float", "min": 0, "max": 100, "default": 25, "unit": "%" }
  ]
}
